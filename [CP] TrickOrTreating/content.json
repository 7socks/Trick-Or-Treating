{
  "Format": "2.6.0",
  "ConfigSchema": {
    "UseCostumesSpiritsEve": {
      "Default": "true",
      "AllowValues": "true, false",
      "Description": "Selects whether NPCs use their costume sprites and portraits at the Spirits Eve Festival."
    },
    "UseCostumesTrickOrTreating": {
      "Default": "true",
      "AllowValues": "true, false",
      "Description": "Selects whether NPCs use their costume sprites and portraits on Fall 28."
    },
    "MinimalMapChanges": {
      "Default": "false",
      "AllowValues": "true, false",
      "Description": "Only include map changes required for functionality"
    }
  },
  "Changes": [
    {
      "LogName": "Patch festival data",
      "Action": "EditData",
      "Target": "Data/PassiveFestivals",
      "Entries": {
        "{{ModId}}_TrickOrTreating": {
          "DisplayName": "Trick-or-Treating",
          "Season": "Fall",
          "StartDay": 28,
          "EndDay": 28,
          "StartTime": 1600,
          "StartMessage": "Trick-or-Treating has begun in Pelican Town!",
          "MapReplacements": {
            "Beach": "Beach",
            "Forest": "Forest",
            "Mountain": "Mountain",
            "Town": "Town"
          }
        }
      }
    },

    {
      "LogName": "Create treats shop",
      "Action": "EditData",
      "Target": "Data/Shops",
      "Entries": {
        "{{ModId}}_CandyShop": {
          "Owners": [
            {
              "Name": "AnyOrNone",
              "Condition": "!TIME 1600 2200",
              "ClosedMessage": "Candy stand open 4PM to 10PM"
            },
            { "Name": "Pierre" }
          ],
          "Items": [
            {
              "ID": "CandyCorn",
              "ItemId": "(O){{ModId}}_CandyCorn",
              "Price": 100,
              "AvailableStock": 10
            },
            {
              "ID": "RedSucker",
              "ItemId": "(O){{ModId}}_RedSucker",
              "Price": 250,
              "AvailableStock": 10
            },
            {
              "ID": "GummySpider",
              "ItemId": "(O){{ModId}}_GummySpider",
              "Price": 250,
              "AvailableStock": 10
            },
            {
              "ID": "ChocolateEyeball",
              "ItemId": "(O){{ModId}}_ChocolateEyeball",
              "Price": 200,
              "AvailableStock": 10
            },
            {
              "ID": "CandyAppleRecipe",
              "ItemId": "{{ModId}}_CandyApple",
              "ObjectInternalName": "{{ModId}}_CandyApple",
              "IsRecipe": true,
              "Price": 1500,
              "Condition": "!PLAYER_HAS_COOKING_RECIPE Current {{ModId}}_CandyApple",
              "ActionsOnPurchase": [
                "MarkCookingRecipeKnown Current {{ModId}}_CandyApple true"
              ]
            }
          ]
        }
      }
    },


    {
      "Action": "Include",
      "FromFile": "assets/locations.json"
    },
    {
      "LogName": "Patch costume sprites",
      "Action": "Include",
      "FromFile": "assets/loadSprites.json"
    },
    {
      "LogName": "Patch schedules",
      "Action": "Include",
      "FromFile": "assets/data/schedules.json"
    },
    {
      "LogName": "Patch custom objects",
      "Action": "Include",
      "FromFile": "assets/objects.json"
    },
    {
      "Action": "Load",
      "Target": "Strings/TrickOrTreat",
      "FromFile": "assets/data/strings.json"
    },

    {
      "LogName": "Reset candy given flag - temporary fix?",
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "Entries": {
        "{{ModId}}_ResetCandy": {
          "Id": "{{ModId}}_ResetCandy",
          "Condition": "IS_PASSIVE_FESTIVAL_TODAY {{ModId}}_TrickOrTreating",
          "Trigger": "DayEnding",
          "MarkActionApplied": false,
          "Actions": [
            "RemoveMail Current TrickOrTreat_Caroline",
            "RemoveMail Current TrickOrTreat_Elliott",
            "RemoveMail Current TrickOrTreat_Emily",
            "RemoveMail Current TrickOrTreat_Evelyn",
            "RemoveMail Current TrickOrTreat_Gus",
            "RemoveMail Current TrickOrTreat_Jodi",
            "RemoveMail Current TrickOrTreat_Harvey",
            "RemoveMail Current TrickOrTreat_Leah",
            "RemoveMail Current TrickOrTreat_Lewis",
            "RemoveMail Current TrickOrTreat_Marnie",
            "RemoveMail Current TrickOrTreat_Robin",
            "RemoveMail Current TrickOrTreat_Willy"
          ]
        }
      }
    }
  ]
}